# Copy this file to backend/.env and fill in your API keys
# All keys are FREE tier - sign up at the URLs below

# Finnhub - 60 req/min free - https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here

# NewsAPI - 100 req/day free - https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Alpha Vantage - 25 req/day free - https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alphavantage_key_here

# Twelve Data (optional) - 800 req/day free, multi-year daily history.
# Recommended: enables reliable 6M/1Y charts when Yahoo is rate-limited.
# Get a free key at https://twelvedata.com/pricing (Basic/free plan)
TWELVE_DATA_KEY=your_twelvedata_key_here

# Server
PORT=3001
NODE_ENV=development
