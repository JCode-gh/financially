# Firebase (frontend) — https://console.firebase.google.com
# Create a project → Project settings → Your apps → Web app → copy config
# Enable Authentication → Sign-in method → Email/Password
# Enable Firestore Database → Start in production mode, then deploy firestore.rules from repo root

VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
